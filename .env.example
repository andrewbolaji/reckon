# Reckon: Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env

# Warehouse (local dev uses Postgres via docker-compose)
WAREHOUSE_TYPE=postgres
POSTGRES_HOST=warehouse
POSTGRES_PORT=5432
POSTGRES_DB=reckon
POSTGRES_USER=reckon
POSTGRES_PASSWORD=reckon_dev

# MongoDB (local dev uses docker-compose)
MONGO_URI=mongodb://mongo:27017
MONGO_DB=reckon

# Reference date for deterministic demo data (all generators anchor to this)
REFERENCE_DATE=2026-07-16T12:00:00

# Data lake (local dev uses /data/lake; swap to S3 in prod)
DATA_LAKE_TYPE=local
DATA_LAKE_PATH=/data/lake
# DATA_LAKE_TYPE=s3
# S3_BUCKET=reckon-data-lake
# AWS_REGION=us-east-1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Metabase
METABASE_PORT=3000
MB_SETUP_TOKEN=<generate-a-uuid-or-random-string>
MB_ADMIN_EMAIL=admin@reckon.local
MB_ADMIN_PASSWORD=<set-a-strong-password>

# MCP Copilot
ANTHROPIC_API_KEY=sk-ant-your-key-here
# COPILOT_AUDIT_LOG=/path/to/audit.log  # optional; defaults to stderr only

# Observability (Phase 3, used only with `make observability` or --profile observability)
# OTEL_ENABLED=true                     # set automatically by `make observability`
# PUSHGATEWAY_URL=http://pushgateway:9091
# METRICS_PORT=9464                     # API metrics port for Prometheus scraping
# GRAFANA_PORT=3002                     # Grafana UI port
# GRAFANA_ADMIN_PASSWORD=admin
# SPLUNK_HEC_URL=https://splunk:8088/services/collector  # forward logs to Splunk
# SPLUNK_HEC_TOKEN=your-hec-token                        # Splunk HEC auth token

# AWS deployment (Phase 2, used by Makefile targets)
# These are read by `make helm-install`; do NOT commit real values.
# WAREHOUSE_TYPE=redshift
# REDSHIFT_HOST=your-cluster.region.redshift-serverless.amazonaws.com
# REDSHIFT_PORT=5439
# REDSHIFT_DB=reckon
# REDSHIFT_USER=reckon_admin
# REDSHIFT_PASSWORD=changeme
