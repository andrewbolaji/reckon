# Reckon — Environment Configuration
# Copy to .env and fill in values

# Warehouse (local dev uses Postgres via docker-compose)
WAREHOUSE_TYPE=postgres
POSTGRES_HOST=warehouse
POSTGRES_PORT=5432
POSTGRES_DB=reckon
POSTGRES_USER=reckon
POSTGRES_PASSWORD=reckon_dev

# AWS (Phase 2 — swap to Redshift)
# WAREHOUSE_TYPE=redshift
# REDSHIFT_HOST=your-cluster.region.redshift-serverless.amazonaws.com
# REDSHIFT_PORT=5439
# REDSHIFT_DB=reckon
# REDSHIFT_USER=admin
# REDSHIFT_PASSWORD=changeme

# Data lake (local dev uses /data/lake; swap to S3 in prod)
DATA_LAKE_TYPE=local
DATA_LAKE_PATH=/data/lake
# DATA_LAKE_TYPE=s3
# S3_BUCKET=reckon-data-lake
# AWS_REGION=us-east-1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Metabase
METABASE_PORT=3000

# AWS deployment (Phase 2 — used by Makefile targets)
# These are read by `make helm-install`; do NOT commit real values.
# REDSHIFT_USER=reckon_admin
# REDSHIFT_PASSWORD=changeme
